{
  "$schema": "https://biomejs.dev/schemas/2.2.0/schema.json",
  "extends": ["ultracite"],
  "javascript": {
    "globals": ["Bun"]
  },
  "json": {
    "parser": {
      "allowComments": true,
      "allowTrailingCommas": true
    }
  },
  "files": {
    "ignoreUnknown": true,
    "includes": ["**/*.{js,jsx,ts,tsx,json,jsonc}"]
  },
  "vcs": {
    "useIgnoreFile": true
  },
  "linter": {
    "rules": {
      "complexity": {
        "noExcessiveLinesPerFunction": "off",
        "noExcessiveCognitiveComplexity": "off"
      },
      "nursery": {
        "useConsistentTypeDefinitions": "off",
        "useMaxParams": "off",
        "noUnnecessaryConditions": "off"
      },
      "suspicious": {
        "noConsole": "off",
        "noExplicitAny": "warn"
      },
      "style": {
        "noExportedImports": "off",
        "noMagicNumbers": "off",
        "useReadonlyClassProperties": "warn"
      },
      "correctness": {
        "noUndeclaredVariables": "warn",
        "noUnusedVariables": "warn"
      }
    }
  }
}
