{
  "name": "rulesets-testing",
  "version": "0.1.0",
  "private": true,
  "description": "Shared testing utilities for Rulesets packages",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "rm -rf dist && tsup && tsc --emitDeclarationOnly",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest watch",
    "lint": "eslint . --ext .ts,.tsx",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@rulesets/parser": "workspace:*",
    "@rulesets/compiler": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^18.19.31",
    "tsup": "^8.0.2",
    "typescript": "^5.4.5",
    "vitest": "^1.6.0",
    "eslint": "^8.57.0"
  },
  "license": "MIT"
}