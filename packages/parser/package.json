{
  "name": "@rulesets/parser",
  "version": "0.1.0",
  "private": false,
  "type": "module",
  "description": "Parser for Rulesets markdown syntax",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "rm -rf dist && bun build src/index.ts --outdir dist --target node --minify && tsc --declaration --emitDeclarationOnly --outDir dist --skipLibCheck src/index.ts",
    "dev": "bun build src/index.ts --outdir dist --target node --watch & tsc --declaration --emitDeclarationOnly --outDir dist --skipLibCheck --watch src/index.ts",
    "test": "bun test",
    "test:watch": "bun test --watch",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@rulesets/types": "workspace:*",
    "js-yaml": "catalog:"
  },
  "devDependencies": {
    "@types/js-yaml": "catalog:",
    "@types/bun": "^1.2.20"
  },
  "publishConfig": {
    "access": "public"
  },
  "license": "MIT"
}
