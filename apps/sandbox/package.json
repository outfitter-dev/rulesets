{
  "name": "rulesets-sandbox",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Interactive sandbox for testing Rulesets compilation with strict TypeScript foundation",
  "keywords": [
    "rulesets",
    "sandbox",
    "typescript",
    "compilation",
    "ai-rules",
    "cursor",
    "claude",
    "windsurf"
  ],
  "author": "Outfitter Development Team",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "<https://github.com/outfitter-dev/rulesets.git>",
    "directory": "apps/sandbox"
  },
  "homepage": "<https://outfitter.dev>",
  "bugs": {
    "url": "<https://github.com/outfitter-dev/rulesets/issues>"
  },
  "bin": {
    "rulesets-sandbox": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "dev": "bun --watch src/index.ts",
    "build": "bun run clean && bun run build:js && bun run build:types",
    "build:js": "bun build src/index.ts --outdir dist --target node --minify",
    "build:types": "tsc --declaration --emitDeclarationOnly --outDir dist",
    "start": "bun src/index.ts",
    "clean": "rm -rf dist output",
    "reset": "bun run clean && mkdir -p output examples",
    "ruleset": "bun run start run",
    "ruleset:clean": "bun run start clean",
    "test": "bun test",
    "test:watch": "bun test --watch",
    "test:coverage": "bun test --coverage",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "typecheck": "tsc --noEmit",
    "format": "biome format --write .",
    "validate": "bun run typecheck && bun run lint && bun run test",
    "ci": "bun run validate && bun run build",
    "prepack": "bun run ci"
  },
  "dependencies": {
    "@rulesets/core": "workspace:*",
    "@rulesets/types": "workspace:*",
    "commander": "^12.0.0",
    "chalk": "^5.3.0",
    "type-fest": "^4.26.1"
  },
  "devDependencies": {
    "@types/bun": "^1.2.20",
    "@types/node": "^22.10.1",
    "@biomejs/biome": "^1.9.4",
    "typescript": "^5.7.2"
  },
  "peerDependencies": {
    "typescript": "^5.7.0"
  },
  "engines": {
    "node": ">=20.0.0",
    "bun": ">=1.0.0"
  },
  "publishConfig": {
    "access": "public",
    "registry": "<https://registry.npmjs.org/>"
  }
}
