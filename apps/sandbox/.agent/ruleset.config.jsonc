{
  // Sandbox Ruleset Configuration
  // This demonstrates a realistic project setup

  "sourceDirectory": "./src",
  "outputDirectory": "../",

  "providers": {
    "cursor": {
      "enabled": true,
      "outputPath": "./.cursor/rules"
    },
    "claude-code": {
      "enabled": true,
      "outputPath": "./CLAUDE.md"
    },
    "windsurf": {
      "enabled": true,
      "outputPath": "./.windsurf/rules.md"
    },
    "amp": {
      "enabled": true,
      "outputPath": "./AGENT.md"
    },
    "codex": {
      "enabled": true,
      "outputPath": "./AGENTS.md"
    }
  },

  "defaultProviders": ["cursor", "claude-code"],

  // Realistic project settings
  "gitignore": {
    "enabled": true,
    "options": {
      "comment": "Rulesets Sandbox - Generated Rules",
      "sort": true
    }
  },

  "strict": true,

  "logging": {
    "level": "info"
  }
}
