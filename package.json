{
  "name": "rulesets",
  "version": "0.1.0",
  "description": "Rules compiler for AI tools",
  "private": true,
  "type": "module",
  "workspaces": ["apps/*", "packages/*"],
  "scripts": {
    "dev": "bun --filter './packages/*' dev",
    "build": "bun --filter './packages/*' build",
    "test": "bun test",
    "test:watch": "bun test --watch",
    "test:coverage": "bun test --coverage",
    "lint": "bun --filter './packages/*' lint",
    "lint:md": "markdownlint-cli2",
    "lint:md:fix": "markdownlint-cli2 --fix",
    "format": "biome format --write . && prettier --write . --ignore-path .prettierignore",
    "format:check": "biome format . && prettier --check . --ignore-path .prettierignore",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "bun --filter '@rulesets/core' build && changeset publish",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist .turbo node_modules bun.lockb",
    "clean:all": "bun run clean && bun --filter '*' clean",
    "prepare": "lefthook install"
  },
  "author": "Maybe Good Systems",
  "license": "MIT",
  "packageManager": "bun@1.2.19",
  "engines": {
    "node": ">=18.0.0",
    "bun": ">=1.1.0"
  },
  "trustedDependencies": [
    "@biomejs/biome",
    "lefthook"
  ],
  "devDependencies": {
    "@biomejs/biome": "2.1.2",
    "@changesets/cli": "^2.29.5",
    "@commitlint/cli": "^19.8.1",
    "@types/bun": "^1.2.19",
    "@types/node": "^18.19.120",
    "lefthook": "^1.12.2",
    "markdownlint-cli2": "^0.13.0",
    "prettier": "^3.2.5",
    "typescript": "^5.8.3",
    "ultracite": "5.0.47"
  }
}