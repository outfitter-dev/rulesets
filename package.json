{
  "name": "rulesets",
  "version": "0.1.0",
  "description": "Rulesets - AI-powered documentation and workflow rules compiler that lets you author a single source rules file in Markdown and compile it into destination-specific rules files",
  "type": "module",
  "private": true,
  "keywords": [
    "monorepo",
    "bun",
    "typescript",
    "ai-rules",
    "markdown",
    "compiler"
  ],
  "author": "Matt Galligan <matt.galligan@gmail.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/outfitter-dev/rulesets.git"
  },
  "workspaces": {
    "packages": [
      "apps/*",
      "packages/*"
    ],
    "catalog": {
      "@types/node": "^24.2.1",
      "typescript": "^5.9.2",
      "type-fest": "^4.41.0",
      "js-yaml": "^4.1.0",
      "@types/js-yaml": "^4.0.9",
      "handlebars": "^4.7.8",
      "@types/handlebars": "^4.1.0"
    }
  },
  "scripts": {
    "build": "bun scripts/build.ts",
    "build:turbo": "turbo build",
    "build:clean": "bun scripts/build.ts --clean",
    "build:watch": "bun scripts/build.ts --watch",
    "dev": "bun scripts/dev.ts",
    "dev:turbo": "turbo dev",
    "test": "bun scripts/test.ts",
    "test:turbo": "turbo test",
    "test:watch": "bun scripts/test.ts --watch",
    "test:coverage": "bun scripts/test.ts --coverage",
    "test:ci": "bun scripts/test.ts --coverage",
    "test:handlebars": "cd packages/compiler && bun test --filter='handlebars|partial'",
    "format": "prettier --write . && markdownlint-cli2 --fix",
    "format:check": "prettier --check . && markdownlint-cli2",
    "lint": "ultracite lint",
    "lint:fix": "ultracite format",
    "lint:packages": "publint",
    "typecheck": "bun scripts/typecheck.ts",
    "typecheck:watch": "tsc --noEmit --watch",
    "typecheck:turbo": "turbo typecheck",
    "typecheck:all": "tsc --noEmit",
    "ci": "bun scripts/build.ts && bun scripts/test.ts && bun scripts/typecheck.ts",
    "ci:turbo": "turbo build test typecheck",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "bun run build:clean && changeset publish",
    "clean": "rm -rf dist node_modules bun.lock",
    "clean:all": "bun run clean && bun run --filter '*' clean",
    "sandbox": "cd apps/sandbox && bun run start",
    "sandbox:clean": "cd apps/sandbox && bun run start clean",
    "lockfile:update": "sed -i '' 's/frozenLockfile = true/frozenLockfile = false/' bunfig.toml && bun install && sed -i '' 's/frozenLockfile = false/frozenLockfile = true/' bunfig.toml",
    "prepare": "lefthook install",
    "commit": "commit",
    "commitlint": "commitlint",
    "pre:commit": "lefthook run pre-commit",
    "pre:push": "lefthook run pre-push",
    "postinstall": "bun run build"
  },
  "packageManager": "bun@1.2.20",
  "engines": {
    "node": ">=20.0.0",
    "bun": ">=1.2.0"
  },
  "trustedDependencies": [
    "@biomejs/biome",
    "lefthook"
  ],
  "devDependencies": {
    "@biomejs/biome": "^2.2.0",
    "@changesets/cli": "^2.29.5",
    "@commitlint/cli": "^19.8.1",
    "@commitlint/config-conventional": "^19.8.1",
    "@commitlint/prompt-cli": "^19.8.1",
    "@types/bun": "^1.2.20",
    "@types/handlebars": "^4.1.0",
    "@types/node": "^24.2.1",
    "handlebars": "^4.7.8",
    "lefthook": "^1.12.3",
    "markdownlint-cli2": "^0.18.1",
    "pino": "^9.9.0",
    "pino-pretty": "^13.1.1",
    "prettier": "^3.6.2",
    "publint": "^0.3.12",
    "syncpack": "^14.0.0-alpha.19",
    "turbo": "^2.5.6",
    "type-fest": "^4.41.0",
    "typedoc": "^0.28.10",
    "typescript": "^5.9.2",
    "ultracite": "^5.1.5"
  }
}
