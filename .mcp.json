{
  "mcpServers": {
    "ultracite": {
      "command": "npx",
      "args": [
        "-y",
        "mcp-remote",
        "https://www.ultracite.ai/api/mcp/mcp"
      ]
    },
    "context7": {
      "type": "http",
      "url": "<https://mcp.context7.com/mcp>"
    },
    "sequential-thinking": {
      "type": "stdio",
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-sequential-thinking"
      ]
    },
    "private-journal": {
      "type": "stdio",
      "command": "npx",
      "args": [
        "github:obra/private-journal-mcp"
      ]
    }
  }
}
